# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Supabase (server only - NEVER expose in client)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase CLI (optional)
SUPABASE_PROJECT_REF=

# PostHog (Analytics / Event Tracking)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Vercel Project (optional metadata)
VERCEL_PROJECT_NAME=
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=

# Optional: direct DB connection (for ORMs/tools/migrations)
DATABASE_URL=

# Optional: DB password (used by `pnpm db:migrate` if DATABASE_URL is not set)
SUPABASE_DB_PASSWORD=
